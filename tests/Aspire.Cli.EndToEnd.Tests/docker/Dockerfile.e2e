# Multi-stage Dockerfile for Aspire CLI E2E testing.
#
# Usage:
#   Local dev (build from source):
#     BuildContext = repo root, no special build args needed.
#     Docker builds the CLI from source and installs it.
#
#   CI (pre-built artifacts):
#     Pass SKIP_SOURCE_BUILD=true as a build arg.
#     Mount pre-built CLI archive via a volume at /artifacts.
#     The test code installs from the mounted artifacts.

# ============================================================
# Stage 1: Build the Aspire CLI from source
# ============================================================
# This stage is skipped when SKIP_SOURCE_BUILD=true (CI mode).
# It builds a framework-dependent publish (no native AOT) for speed.
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build

ARG SKIP_SOURCE_BUILD=false

WORKDIR /repo

# Copy build infrastructure first for better layer caching.
COPY global.json ./
COPY NuGet.config ./
COPY Directory.Build.props ./
COPY Directory.Build.targets ./
COPY Directory.Packages.props ./
COPY eng/ eng/

# Copy the CLI project and its source dependencies.
COPY src/Aspire.Cli/ src/Aspire.Cli/
COPY src/Shared/ src/Shared/
COPY src/Aspire.Hosting/Backchannel/BackchannelDataTypes.cs src/Aspire.Hosting/Backchannel/BackchannelDataTypes.cs
COPY src/Aspire.Hosting/ApplicationModel/KnownResourceCommands.cs src/Aspire.Hosting/ApplicationModel/KnownResourceCommands.cs
COPY src/Aspire.Hosting/Ats/RuntimeSpec.cs src/Aspire.Hosting/Ats/RuntimeSpec.cs

# Restore and publish the CLI (framework-dependent, no AOT).
# The RUN is conditional on SKIP_SOURCE_BUILD so CI can skip it entirely.
RUN if [ "$SKIP_SOURCE_BUILD" != "true" ]; then \
      dotnet restore src/Aspire.Cli/Aspire.Cli.csproj && \
      dotnet publish src/Aspire.Cli/Aspire.Cli.csproj \
        -c Release \
        --no-restore \
        -o /cli-publish \
        /p:PublishAot=false \
        /p:IsCliToolProject=false; \
    else \
      mkdir -p /cli-publish; \
    fi

# ============================================================
# Stage 2: Test runtime environment
# ============================================================
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS runtime

# Copy the published CLI from the build stage (empty when SKIP_SOURCE_BUILD=true).
COPY --from=build /cli-publish/ /root/.aspire/bin/

# Ensure the CLI binary is executable (no-op if directory is empty).
RUN chmod +x /root/.aspire/bin/aspire 2>/dev/null || true

ENV PATH="/root/.aspire/bin:${PATH}"
ENV DOTNET_CLI_TELEMETRY_OPTOUT=1
ENV DOTNET_SKIP_FIRST_TIME_EXPERIENCE=1
ENV DOTNET_GENERATE_ASPNET_CERTIFICATE=false
