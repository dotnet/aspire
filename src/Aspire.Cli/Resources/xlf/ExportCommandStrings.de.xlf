<?xml version="1.0" encoding="utf-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="1.2" xsi:schemaLocation="urn:oasis:names:tc:xliff:document:1.2 xliff-core-1.2-transitional.xsd">
  <file datatype="xml" source-language="en" target-language="de" original="../ExportCommandStrings.resx">
    <body>
      <trans-unit id="DashboardNotAvailable">
        <source>Dashboard is not available. Telemetry data (structured logs, traces) will not be included in the export.</source>
        <target state="translated">Dashboard nicht verfügbar. Telemetriedaten (strukturierte Protokolle, Traces) werden nicht in den Export aufgenommen.</target>
        <note />
      </trans-unit>
      <trans-unit id="Description">
        <source>Export telemetry and resource data to a zip file</source>
        <target state="translated">Telemetrie- und Ressourcendaten in eine ZIP-Datei exportieren</target>
        <note />
      </trans-unit>
      <trans-unit id="ExportComplete">
        <source>Export saved to {0}</source>
        <target state="translated">Export in {0} gespeichert</target>
        <note />
      </trans-unit>
      <trans-unit id="FailedToExport">
        <source>Failed to export resource and telemetry data: {0}</source>
        <target state="translated">Fehler beim Exportieren von Ressourcen- und Telemetriedaten: {0}</target>
        <note />
      </trans-unit>
      <trans-unit id="GatheringConsoleLogs">
        <source>Gathering console logs...</source>
        <target state="translated">Konsolenprotokolle werden gesammelt …</target>
        <note />
      </trans-unit>
      <trans-unit id="GatheringResources">
        <source>Gathering resource data...</source>
        <target state="translated">Ressourcendaten werden gesammelt …</target>
        <note />
      </trans-unit>
      <trans-unit id="GatheringStructuredLogs">
        <source>Gathering structured logs...</source>
        <target state="translated">Strukturierte Protokolle werden gesammelt …</target>
        <note />
      </trans-unit>
      <trans-unit id="GatheringTraces">
        <source>Gathering traces...</source>
        <target state="translated">Traces werden gesammelt …</target>
        <note />
      </trans-unit>
      <trans-unit id="NoResourcesFound">
        <source>No resources found.</source>
        <target state="translated">Keine Ressourcen gefunden.</target>
        <note />
      </trans-unit>
      <trans-unit id="OutputOptionDescription">
        <source>The output file path for the export zip file</source>
        <target state="translated">Der Ausgabedateipfad für die Export-ZIP-Datei</target>
        <note />
      </trans-unit>
      <trans-unit id="ResourceNotFound">
        <source>Resource '{0}' not found.</source>
        <target state="translated">Die Ressource "{0}" wurde nicht gefunden.</target>
        <note />
      </trans-unit>
      <trans-unit id="ResourceOptionDescription">
        <source>Export data only for the specified resource</source>
        <target state="translated">Nur Daten für die angegebene Ressource exportieren</target>
        <note />
      </trans-unit>
      <trans-unit id="SelectAppHostAction">
        <source>export data from</source>
        <target state="translated">Daten exportieren aus</target>
        <note />
      </trans-unit>
    </body>
  </file>
</xliff>