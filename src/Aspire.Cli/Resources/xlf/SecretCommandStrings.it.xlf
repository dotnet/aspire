<?xml version="1.0" encoding="utf-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="1.2" xsi:schemaLocation="urn:oasis:names:tc:xliff:document:1.2 xliff-core-1.2-transitional.xsd">
  <file datatype="xml" source-language="en" target-language="it" original="../SecretCommandStrings.resx">
    <body>
      <trans-unit id="CouldNotFindAppHost">
        <source>Could not find an AppHost project.</source>
        <target state="translated">Non è possibile trovare un progetto AppHost.</target>
        <note />
      </trans-unit>
      <trans-unit id="DeleteDescription">
        <source>Delete a secret.</source>
        <target state="translated">Consente di eliminare un segreto.</target>
        <note />
      </trans-unit>
      <trans-unit id="Description">
        <source>Manage AppHost user secrets.</source>
        <target state="translated">Gestire i segreti utente di AppHost.</target>
        <note />
      </trans-unit>
      <trans-unit id="FormatOptionDescription">
        <source>Output format.</source>
        <target state="translated">Formato dell'output.</target>
        <note />
      </trans-unit>
      <trans-unit id="GetDescription">
        <source>Get a secret value.</source>
        <target state="translated">Ottieni un valore segreto.</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyArgumentDescription">
        <source>The secret key (e.g., Azure:Location or Parameters:postgres-password).</source>
        <target state="translated">La chiave privata (ad esempio, Azure:Location o Parameters:postgres-password).</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyDeleteArgumentDescription">
        <source>The secret key to delete.</source>
        <target state="translated">Chiave privata da eliminare.</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyRetrieveArgumentDescription">
        <source>The secret key to retrieve.</source>
        <target state="translated">Chiave privata da recuperare.</target>
        <note />
      </trans-unit>
      <trans-unit id="ListDescription">
        <source>List all secrets.</source>
        <target state="translated">Elenca tutti i segreti.</target>
        <note />
      </trans-unit>
      <trans-unit id="NoSecretsConfigured">
        <source>No secrets configured.</source>
        <target state="translated">Nessun segreto configurato.</target>
        <note />
      </trans-unit>
      <trans-unit id="SecretDeleteSuccess">
        <source>Secret '{0}' deleted successfully.</source>
        <target state="translated">L'eliminazione del segreto '{0}' è stata completata.</target>
        <note />
      </trans-unit>
      <trans-unit id="SecretNotFound">
        <source>Secret '{0}' not found.</source>
        <target state="translated">Segreto {0} non trovato.</target>
        <note />
      </trans-unit>
      <trans-unit id="SecretSetSuccess">
        <source>Secret '{0}' set successfully.</source>
        <target state="translated">Il segreto '{0}' è stato impostato.</target>
        <note />
      </trans-unit>
      <trans-unit id="SetDescription">
        <source>Set a secret value.</source>
        <target state="translated">Imposta un valore segreto.</target>
        <note />
      </trans-unit>
      <trans-unit id="ValueArgumentDescription">
        <source>The secret value to set.</source>
        <target state="translated">Valore del segreto da impostare.</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyColumnHeader">
        <source>Key</source>
        <target state="translated">Chiave</target>
        <note />
      </trans-unit>
      <trans-unit id="ValueColumnHeader">
        <source>Value</source>
        <target state="translated">Valore</target>
        <note />
      </trans-unit>
