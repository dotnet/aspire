<?xml version="1.0" encoding="utf-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="1.2" xsi:schemaLocation="urn:oasis:names:tc:xliff:document:1.2 xliff-core-1.2-transitional.xsd">
  <file datatype="xml" source-language="en" target-language="tr" original="../LogsCommandStrings.resx">
    <body>
      <trans-unit id="Description">
        <source>Display logs from resources in a running apphost.</source>
        <target state="needs-review-translation">Çalışan bir Aspire apphost'taki kaynakların günlüklerini görüntüle.</target>
        <note />
      </trans-unit>
      <trans-unit id="FollowOptionDescription">
        <source>Stream logs in real-time as they are written.</source>
        <target state="translated">Günlükleri yazıldıkça gerçek zamanlı olarak akışla aktar.</target>
        <note />
      </trans-unit>
      <trans-unit id="JsonOptionDescription">
        <source>Output format (Table or Json).</source>
        <target state="needs-review-translation">Günlükleri JSON biçiminde (NDJSON) çıkar.</target>
        <note />
      </trans-unit>
      <trans-unit id="NoResourcesFound">
        <source>No resources found.</source>
        <target state="translated">Kaynak bulunamadı.</target>
        <note />
      </trans-unit>
      <trans-unit id="ResourceArgumentDescription">
        <source>The name of the resource to get logs for. If not specified, logs from all resources are shown.</source>
        <target state="translated">Günlükleri alınacak kaynağın adı. Belirtilmezse tüm kaynakların günlükleri gösterilir.</target>
        <note />
      </trans-unit>
      <trans-unit id="ScanningForRunningAppHosts">
        <source>Scanning for running AppHosts...</source>
        <target state="translated">Çalışan AppHost'lar taranıyor...</target>
        <note />
      </trans-unit>
      <trans-unit id="SelectAppHost">
        <source>Select an AppHost:</source>
        <target state="translated">AppHost seçin:</target>
        <note />
      </trans-unit>
      <trans-unit id="TailMustBePositive">
        <source>The --tail value must be a positive number.</source>
        <target state="translated">--tail değeri, pozitif bir sayı olmalıdır.</target>
        <note />
      </trans-unit>
      <trans-unit id="TailOptionDescription">
        <source>Number of lines to show from the end of logs (default: all).</source>
        <target state="translated">Günlüklerin sonundan gösterilecek satır sayısı (varsayılan: tümü).</target>
        <note />
      </trans-unit>
    </body>
  </file>
</xliff>