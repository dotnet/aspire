<?xml version="1.0" encoding="utf-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="1.2" xsi:schemaLocation="urn:oasis:names:tc:xliff:document:1.2 xliff-core-1.2-transitional.xsd">
  <file datatype="xml" source-language="en" target-language="tr" original="../SecretCommandStrings.resx">
    <body>
      <trans-unit id="CouldNotFindAppHost">
        <source>Could not find an AppHost project.</source>
        <target state="translated">AppHost projesi bulunamadı.</target>
        <note />
      </trans-unit>
      <trans-unit id="DeleteDescription">
        <source>Delete a secret.</source>
        <target state="translated">Bir gizli diziyi silin.</target>
        <note />
      </trans-unit>
      <trans-unit id="Description">
        <source>Manage AppHost user secrets.</source>
        <target state="translated">AppHost kullanıcı gizli dizilerini yönetin.</target>
        <note />
      </trans-unit>
      <trans-unit id="FormatOptionDescription">
        <source>Output format.</source>
        <target state="translated">Çıktı biçimi.</target>
        <note />
      </trans-unit>
      <trans-unit id="GetDescription">
        <source>Get a secret value.</source>
        <target state="translated">Gizli dizi değerini alın.</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyArgumentDescription">
        <source>The secret key (e.g., Azure:Location or Parameters:postgres-password).</source>
        <target state="translated">Gizli anahtar (örneğin Azure:Location veya Parameters:postgres-password).</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyDeleteArgumentDescription">
        <source>The secret key to delete.</source>
        <target state="translated">Silinecek gizli anahtar.</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyRetrieveArgumentDescription">
        <source>The secret key to retrieve.</source>
        <target state="translated">Alınacak gizli anahtar.</target>
        <note />
      </trans-unit>
      <trans-unit id="ListDescription">
        <source>List all secrets.</source>
        <target state="translated">Tüm gizli dizileri listeleyin.</target>
        <note />
      </trans-unit>
      <trans-unit id="NoSecretsConfigured">
        <source>No secrets configured.</source>
        <target state="translated">Hiç gizli dizi yapılandırılmadı.</target>
        <note />
      </trans-unit>
      <trans-unit id="SecretDeleteSuccess">
        <source>Secret '{0}' deleted successfully.</source>
        <target state="translated">'{0}' gizli dizisi başarıyla silindi.</target>
        <note />
      </trans-unit>
      <trans-unit id="SecretNotFound">
        <source>Secret '{0}' not found.</source>
        <target state="translated">'{0}' gizli dizisi bulunamadı.</target>
        <note />
      </trans-unit>
      <trans-unit id="SecretSetSuccess">
        <source>Secret '{0}' set successfully.</source>
        <target state="translated">'{0}' gizli dizisi başarıyla ayarlandı.</target>
        <note />
      </trans-unit>
      <trans-unit id="SetDescription">
        <source>Set a secret value.</source>
        <target state="translated">Gizli dizi değerini ayarlayın.</target>
        <note />
      </trans-unit>
      <trans-unit id="ValueArgumentDescription">
        <source>The secret value to set.</source>
        <target state="translated">Ayarlanacak gizli dizi değeri.</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyColumnHeader">
        <source>Key</source>
        <target state="translated">Anahtar</target>
        <note />
      </trans-unit>
      <trans-unit id="ValueColumnHeader">
        <source>Value</source>
        <target state="translated">Değer</target>
        <note />
      </trans-unit>
    </body>
  </file>
