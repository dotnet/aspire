<?xml version="1.0" encoding="utf-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="1.2" xsi:schemaLocation="urn:oasis:names:tc:xliff:document:1.2 xliff-core-1.2-transitional.xsd">
  <file datatype="xml" source-language="en" target-language="pt-BR" original="../SecretCommandStrings.resx">
    <body>
      <trans-unit id="CouldNotFindAppHost">
        <source>Could not find an AppHost project.</source>
        <target state="translated">Não foi possível localizar um projeto AppHost.</target>
        <note />
      </trans-unit>
      <trans-unit id="DeleteDescription">
        <source>Delete a secret.</source>
        <target state="translated">Exclua um segredo.</target>
        <note />
      </trans-unit>
      <trans-unit id="Description">
        <source>Manage AppHost user secrets.</source>
        <target state="translated">Gerencie segredos de usuário do AppHost.</target>
        <note />
      </trans-unit>
      <trans-unit id="FormatOptionDescription">
        <source>Output format.</source>
        <target state="translated">Formato de saída.</target>
        <note />
      </trans-unit>
      <trans-unit id="GetDescription">
        <source>Get a secret value.</source>
        <target state="translated">Obtenha um valor do segredo.</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyArgumentDescription">
        <source>The secret key (e.g., Azure:Location or Parameters:postgres-password).</source>
        <target state="translated">A chave secreta (por exemplo, Azure:Location ou Parameters:postgres-password).</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyDeleteArgumentDescription">
        <source>The secret key to delete.</source>
        <target state="translated">A chave secreta a ser excluída.</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyRetrieveArgumentDescription">
        <source>The secret key to retrieve.</source>
        <target state="translated">A chave secreta a ser recuperada.</target>
        <note />
      </trans-unit>
      <trans-unit id="ListDescription">
        <source>List all secrets.</source>
        <target state="translated">Listar todos os segredos.</target>
        <note />
      </trans-unit>
      <trans-unit id="NoSecretsConfigured">
        <source>No secrets configured.</source>
        <target state="translated">Nenhum segredo configurado.</target>
        <note />
      </trans-unit>
      <trans-unit id="SecretDeleteSuccess">
        <source>Secret '{0}' deleted successfully.</source>
        <target state="translated">Segredo '{0}' excluído com êxito.</target>
        <note />
      </trans-unit>
      <trans-unit id="SecretNotFound">
        <source>Secret '{0}' not found.</source>
        <target state="translated">Segredo '{0}' não encontrado.</target>
        <note />
      </trans-unit>
      <trans-unit id="SecretSetSuccess">
        <source>Secret '{0}' set successfully.</source>
        <target state="translated">Segredo '{0}' definido com êxito.</target>
        <note />
      </trans-unit>
      <trans-unit id="SetDescription">
        <source>Set a secret value.</source>
        <target state="translated">Defina um valor do segredo.</target>
        <note />
      </trans-unit>
      <trans-unit id="ValueArgumentDescription">
        <source>The secret value to set.</source>
        <target state="translated">O valor do segredo a ser definido.</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyColumnHeader">
        <source>Key</source>
        <target state="translated">Chave</target>
        <note />
      </trans-unit>
      <trans-unit id="ValueColumnHeader">
        <source>Value</source>
        <target state="translated">Valor</target>
        <note />
      </trans-unit>
    </body>
