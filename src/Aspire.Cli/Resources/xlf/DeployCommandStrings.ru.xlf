<?xml version="1.0" encoding="utf-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="1.2" xsi:schemaLocation="urn:oasis:names:tc:xliff:document:1.2 xliff-core-1.2-transitional.xsd">
  <file datatype="xml" source-language="en" target-language="ru" original="../DeployCommandStrings.resx">
    <body>
      <trans-unit id="ClearCacheOptionDescription">
        <source>Clear the deployment cache associated with the current environment and do not save deployment state</source>
        <target state="translated">Очистить кэш развертывания, связанный с текущей средой, и не сохранять состояние развертывания</target>
        <note />
      </trans-unit>
      <trans-unit id="DeploymentCanceled">
        <source>The deployment was canceled.</source>
        <target state="translated">Развертывание было отменено.</target>
        <note />
      </trans-unit>
      <trans-unit id="Description">
        <source>Deploy an apphost to its deployment targets (Preview)</source>
        <target state="translated">Развернуть хост приложений в целевых объектах развертывания (предварительная версия)</target>
        <note />
      </trans-unit>
      <trans-unit id="OperationCompletedPrefix">
        <source>DEPLOYMENT COMPLETED</source>
        <target state="translated">РАЗВЕРТЫВАНИЕ ЗАВЕРШЕНО</target>
        <note />
      </trans-unit>
      <trans-unit id="OperationFailedPrefix">
        <source>DEPLOYMENT FAILED</source>
        <target state="translated">СБОЙ РАЗВЕРТЫВАНИЯ</target>
        <note />
      </trans-unit>
      <trans-unit id="OutputPathArgumentDescription">
        <source>The optional output path for deployment artifacts</source>
        <target state="translated">Необязательный путь вывода для артефактов развертывания</target>
        <note />
      </trans-unit>
    </body>
  </file>
</xliff>