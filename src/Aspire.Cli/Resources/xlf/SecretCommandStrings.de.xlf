<?xml version="1.0" encoding="utf-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="1.2" xsi:schemaLocation="urn:oasis:names:tc:xliff:document:1.2 xliff-core-1.2-transitional.xsd">
  <file datatype="xml" source-language="en" target-language="de" original="../SecretCommandStrings.resx">
    <body>
      <trans-unit id="CouldNotFindAppHost">
        <source>Could not find an AppHost project.</source>
        <target state="translated">Es wurde kein AppHost-Projekt gefunden.</target>
        <note />
      </trans-unit>
      <trans-unit id="DeleteDescription">
        <source>Delete a secret.</source>
        <target state="translated">Löschen Sie ein Geheimnis.</target>
        <note />
      </trans-unit>
      <trans-unit id="Description">
        <source>Manage AppHost user secrets.</source>
        <target state="translated">Verwalten Sie AppHost-Benutzergeheimnisse.</target>
        <note />
      </trans-unit>
      <trans-unit id="FormatOptionDescription">
        <source>Output format.</source>
        <target state="translated">Ausgabeformat.</target>
        <note />
      </trans-unit>
      <trans-unit id="GetDescription">
        <source>Get a secret value.</source>
        <target state="translated">Rufen Sie einen Geheimniswert ab.</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyArgumentDescription">
        <source>The secret key (e.g., Azure:Location or Parameters:postgres-password).</source>
        <target state="translated">Der geheime Schlüssel (z. B. Azure:Location oder Parameters:postgres-password).</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyDeleteArgumentDescription">
        <source>The secret key to delete.</source>
        <target state="translated">Der zu löschende geheime Schlüssel.</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyRetrieveArgumentDescription">
        <source>The secret key to retrieve.</source>
        <target state="translated">Der geheime Schlüssel, der abgerufen werden soll.</target>
        <note />
      </trans-unit>
      <trans-unit id="ListDescription">
        <source>List all secrets.</source>
        <target state="translated">Listet alle Geheimnisse auf.</target>
        <note />
      </trans-unit>
      <trans-unit id="NoSecretsConfigured">
        <source>No secrets configured.</source>
        <target state="translated">Keine Geheimnisse konfiguriert.</target>
        <note />
      </trans-unit>
      <trans-unit id="SecretDeleteSuccess">
        <source>Secret '{0}' deleted successfully.</source>
        <target state="translated">Das Geheimnis „{0}“ wurde erfolgreich gelöscht.</target>
        <note />
      </trans-unit>
      <trans-unit id="SecretNotFound">
        <source>Secret '{0}' not found.</source>
        <target state="translated">Geheimnis „{0}“ nicht gefunden.</target>
        <note />
      </trans-unit>
      <trans-unit id="SecretSetSuccess">
        <source>Secret '{0}' set successfully.</source>
        <target state="translated">Das Geheimnis „{0}“ wurde erfolgreich festgelegt.</target>
        <note />
      </trans-unit>
      <trans-unit id="SetDescription">
        <source>Set a secret value.</source>
        <target state="translated">Legen Sie einen Geheimniswert fest.</target>
        <note />
      </trans-unit>
      <trans-unit id="ValueArgumentDescription">
        <source>The secret value to set.</source>
        <target state="translated">Der geheime Wert, der festgelegt werden soll.</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyColumnHeader">
        <source>Key</source>
        <target state="translated">Schlüssel</target>
        <note />
      </trans-unit>
      <trans-unit id="ValueColumnHeader">
        <source>Value</source>
        <target state="translated">Wert</target>
        <note />
      </trans-unit>
    </body>
  </file>
</xliff>