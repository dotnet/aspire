<?xml version="1.0" encoding="utf-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="1.2" xsi:schemaLocation="urn:oasis:names:tc:xliff:document:1.2 xliff-core-1.2-transitional.xsd">
  <file datatype="xml" source-language="en" target-language="tr" original="../CertificatesCommandStrings.resx">
    <body>
      <trans-unit id="CleanCancelled">
        <source>Certificate clean operation was cancelled by the user.</source>
        <target state="translated">Kullanıcı, sertifika temizleme işlemini iptal etti.</target>
        <note />
      </trans-unit>
      <trans-unit id="CleanDescription">
        <source>Remove all HTTPS development certificates</source>
        <target state="translated">Tüm HTTPS geliştirme sertifikalarını kaldır</target>
        <note />
      </trans-unit>
      <trans-unit id="CleanFailure">
        <source>Failed to clean HTTPS development certificates.</source>
        <target state="translated">HTTPS geliştirme sertifikaları temizlenemedi.</target>
        <note />
      </trans-unit>
      <trans-unit id="CleanFailureDetailsFormat">
        <source>Certificate clean operation failed: {0}</source>
        <target state="translated">Sertifika doğrulama işlemi başarısız oldu: {0}</target>
        <note>{0} is the error message from the failed operation</note>
      </trans-unit>
      <trans-unit id="CleanProgress">
        <source>Cleaning development certificates (may require elevated permissions)...</source>
        <target state="translated">Geliştirme sertifikaları temizleniyor (yüksek düzeyde izinler gerekebilir)...</target>
        <note />
      </trans-unit>
      <trans-unit id="CleanSuccess">
        <source>All HTTPS development certificates cleaned successfully.</source>
        <target state="translated">Tüm HTTPS geliştirme sertifikaları başarıyla temizlendi.</target>
        <note />
      </trans-unit>
      <trans-unit id="Description">
        <source>Manage HTTPS development certificates</source>
        <target state="translated">HTTPS geliştirme sertifikalarını yönet</target>
        <note />
      </trans-unit>
      <trans-unit id="TrustCancelled">
        <source>Certificate trust operation was cancelled by the user.</source>
        <target state="translated">Sertifika güven işlemi kullanıcı tarafından iptal edildi.</target>
        <note />
      </trans-unit>
      <trans-unit id="TrustDescription">
        <source>Trust the HTTPS development certificate, creating one if necessary</source>
        <target state="translated">HTTPS geliştirme sertifikasına güvenin; gerekirse bir tane oluştur</target>
        <note />
      </trans-unit>
      <trans-unit id="TrustFailure">
        <source>Failed to trust HTTPS development certificate.</source>
        <target state="translated">HTTPS geliştirme sertifikasına güvenilemedi.</target>
        <note />
      </trans-unit>
      <trans-unit id="TrustFailureDetailsFormat">
        <source>Certificate trust operation returned: {0}</source>
        <target state="translated">Sertifika güven işlemi sonucu: {0}</target>
        <note>{0} is the EnsureCertificateResult value</note>
      </trans-unit>
      <trans-unit id="TrustProgress">
        <source>Trusting development certificate (may require elevated permissions)...</source>
        <target state="translated">Geliştirme sertifikasına güveniliyor (yükseltilmiş izinler gerekebilir)...</target>
        <note />
      </trans-unit>
      <trans-unit id="TrustSuccess">
        <source>HTTPS development certificate trusted successfully.</source>
        <target state="translated">HTTPS geliştirme sertifikası başarıyla doğrulandı.</target>
        <note />
      </trans-unit>
    </body>
  </file>
</xliff>