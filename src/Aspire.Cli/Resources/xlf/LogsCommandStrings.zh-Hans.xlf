<?xml version="1.0" encoding="utf-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="1.2" xsi:schemaLocation="urn:oasis:names:tc:xliff:document:1.2 xliff-core-1.2-transitional.xsd">
  <file datatype="xml" source-language="en" target-language="zh-Hans" original="../LogsCommandStrings.resx">
    <body>
      <trans-unit id="Description">
        <source>Display logs from resources in a running apphost.</source>
        <target state="needs-review-translation">显示正在运行的 Aspire 应用主机中资源的日志。</target>
        <note />
      </trans-unit>
      <trans-unit id="FollowOptionDescription">
        <source>Stream logs in real-time as they are written.</source>
        <target state="translated">在写入日志时实时流式传输这些日志。</target>
        <note />
      </trans-unit>
      <trans-unit id="GettingLogs">
        <source>Getting logs...</source>
        <target state="new">Getting logs...</target>
        <note />
      </trans-unit>
      <trans-unit id="JsonOptionDescription">
        <source>Output format (Table or Json).</source>
        <target state="needs-review-translation">以 JSON 格式输出日志(NDJSON)。</target>
        <note />
      </trans-unit>
      <trans-unit id="NoResourcesFound">
        <source>No resources found.</source>
        <target state="translated">未找到资源。</target>
        <note />
      </trans-unit>
      <trans-unit id="ResourceArgumentDescription">
        <source>The name of the resource to get logs for. If not specified, logs from all resources are shown.</source>
        <target state="translated">要获取其日志的资源的名称。如果未指定，则显示所有资源的日志。</target>
        <note />
      </trans-unit>
      <trans-unit id="ResourceNotFound">
        <source>Resource '{0}' was not found.</source>
        <target state="new">Resource '{0}' was not found.</target>
        <note />
      </trans-unit>
      <trans-unit id="SelectAppHostAction">
        <source>stream logs from</source>
        <target state="new">stream logs from</target>
        <note />
      </trans-unit>
      <trans-unit id="TailMustBePositive">
        <source>The --tail value must be a positive number.</source>
        <target state="translated">--tail 值必须为正数。</target>
        <note />
      </trans-unit>
      <trans-unit id="TailOptionDescription">
        <source>Number of lines to show from the end of logs (default: all).</source>
        <target state="translated">要在日志末尾显示的行数(默认: 全部)。</target>
        <note />
      </trans-unit>
      <trans-unit id="TimestampsOptionDescription">
        <source>Show timestamps for each log line.</source>
        <target state="new">Show timestamps for each log line.</target>
        <note />
      </trans-unit>
    </body>
  </file>
</xliff>