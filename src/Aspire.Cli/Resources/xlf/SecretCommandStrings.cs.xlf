<?xml version="1.0" encoding="utf-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="1.2" xsi:schemaLocation="urn:oasis:names:tc:xliff:document:1.2 xliff-core-1.2-transitional.xsd">
  <file datatype="xml" source-language="en" target-language="cs" original="../SecretCommandStrings.resx">
    <body>
      <trans-unit id="CouldNotFindAppHost">
        <source>Could not find an AppHost project.</source>
        <target state="translated">Nepovedlo se najít projekt AppHost.</target>
        <note />
      </trans-unit>
      <trans-unit id="DeleteDescription">
        <source>Delete a secret.</source>
        <target state="translated">Odstraní tajný kód.</target>
        <note />
      </trans-unit>
      <trans-unit id="Description">
        <source>Manage AppHost user secrets.</source>
        <target state="translated">Správa tajných kódů uživatelů AppHost</target>
        <note />
      </trans-unit>
      <trans-unit id="FormatOptionDescription">
        <source>Output format.</source>
        <target state="translated">Výstupní formát</target>
        <note />
      </trans-unit>
      <trans-unit id="GetDescription">
        <source>Get a secret value.</source>
        <target state="translated">Získá hodnotu tajného kódu.</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyArgumentDescription">
        <source>The secret key (e.g., Azure:Location or Parameters:postgres-password).</source>
        <target state="translated">Tajný kód (např. Azure:Location nebo Parameters:postgres-password)</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyDeleteArgumentDescription">
        <source>The secret key to delete.</source>
        <target state="translated">Tajný kód, který se má odstranit</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyRetrieveArgumentDescription">
        <source>The secret key to retrieve.</source>
        <target state="translated">Tajný klíč, který se má načíst</target>
        <note />
      </trans-unit>
      <trans-unit id="ListDescription">
        <source>List all secrets.</source>
        <target state="translated">Vypíše všechny tajné kódy.</target>
        <note />
      </trans-unit>
      <trans-unit id="NoSecretsConfigured">
        <source>No secrets configured.</source>
        <target state="translated">Nejsou nakonfigurované žádné tajné kódy.</target>
        <note />
      </trans-unit>
      <trans-unit id="SecretDeleteSuccess">
        <source>Secret '{0}' deleted successfully.</source>
        <target state="translated">Tajný kód {0} byl úspěšně odstraněn.</target>
        <note />
      </trans-unit>
      <trans-unit id="SecretNotFound">
        <source>Secret '{0}' not found.</source>
        <target state="translated">Nebyl nalezen tajný kód: {0}.</target>
        <note />
      </trans-unit>
      <trans-unit id="SecretSetSuccess">
        <source>Secret '{0}' set successfully.</source>
        <target state="translated">Tajný kód {0} se úspěšně nastavil.</target>
        <note />
      </trans-unit>
      <trans-unit id="SetDescription">
        <source>Set a secret value.</source>
        <target state="translated">Nastavte hodnotu tajného kódu.</target>
        <note />
      </trans-unit>
      <trans-unit id="ValueArgumentDescription">
        <source>The secret value to set.</source>
        <target state="translated">Hodnota tajného kódu, která se má nastavit</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyColumnHeader">
        <source>Key</source>
        <target state="translated">Klíč</target>
        <note />
      </trans-unit>
      <trans-unit id="ValueColumnHeader">
        <source>Value</source>
        <target state="translated">Hodnota</target>
        <note />
      </trans-unit>
    </body>
  </file>
</xliff>