<?xml version="1.0" encoding="utf-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="1.2" xsi:schemaLocation="urn:oasis:names:tc:xliff:document:1.2 xliff-core-1.2-transitional.xsd">
  <file datatype="xml" source-language="en" target-language="ko" original="../SecretCommandStrings.resx">
    <body>
      <trans-unit id="CouldNotFindAppHost">
        <source>Could not find an apphost project.</source>
        <target state="translated">apphost 프로젝트를 찾을 수 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="DeleteDescription">
        <source>Delete a secret</source>
        <target state="translated">비밀 삭제</target>
        <note />
      </trans-unit>
      <trans-unit id="Description">
        <source>Manage apphost user secrets</source>
        <target state="translated">apphost 사용자 비밀 관리</target>
        <note />
      </trans-unit>
      <trans-unit id="FormatOptionDescription">
        <source>Output format</source>
        <target state="translated">출력 형식</target>
        <note />
      </trans-unit>
      <trans-unit id="GetDescription">
        <source>Get a secret value</source>
        <target state="translated">비밀 값 가져오기</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyArgumentDescription">
        <source>The secret key (e.g., Azure:Location or Parameters:postgres-password)</source>
        <target state="translated">비밀 키(예: Azure:Location 또는 Parameters:postgres-password)</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyDeleteArgumentDescription">
        <source>The secret key to delete</source>
        <target state="translated">삭제할 비밀 키</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyRetrieveArgumentDescription">
        <source>The secret key to retrieve</source>
        <target state="translated">검색할 비밀 키</target>
        <note />
      </trans-unit>
      <trans-unit id="ListDescription">
        <source>List all secrets</source>
        <target state="translated">모든 비밀 나열</target>
        <note />
      </trans-unit>
      <trans-unit id="NoSecretsConfigured">
        <source>No secrets configured.</source>
        <target state="translated">구성된 비밀이 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="PathDescription">
        <source>Show the secrets file path.</source>
        <target state="translated">비밀 파일 경로를 표시합니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="SecretDeleteSuccess">
        <source>Secret '{0}' deleted successfully.</source>
        <target state="translated">비밀 '{0}'을(를) 삭제했습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="SecretNotFound">
        <source>Secret '{0}' not found.</source>
        <target state="translated">비밀 '{0}'을(를) 찾을 수 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="SecretSetSuccess">
        <source>Secret '{0}' set successfully.</source>
        <target state="translated">비밀 '{0}'을(를) 설정했습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="SetDescription">
        <source>Set a secret value</source>
        <target state="translated">비밀 값 설정</target>
        <note />
      </trans-unit>
      <trans-unit id="ValueArgumentDescription">
        <source>The secret value to set</source>
        <target state="translated">설정할 비밀 값입니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="KeyColumnHeader">
        <source>Key</source>
        <target state="translated">키</target>
        <note />
      </trans-unit>
      <trans-unit id="ValueColumnHeader">
        <source>Value</source>
        <target state="translated">값</target>
        <note />
      </trans-unit>
    </body>
  </file>
</xliff>