  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "tsx --test test/*.ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "license": "MIT"
}
