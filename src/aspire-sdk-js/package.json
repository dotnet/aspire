{
  "name": "@aspire/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for automating the Aspire CLI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
