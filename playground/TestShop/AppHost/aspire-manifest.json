{
  "resources": {
    "postgres": {
      "type": "azure.bicep.v0",
      "path": "postgres-containerapp.bicep",
      "params": {
        "param_0": "{containerAppEnv.outputs.id}",
        "param_1": "{postgres-containerApp.inputs.password}"
      },
      "inputs": {
        "password": {
          "type": "string",
          "secret": true,
          "default": {
            "generate": {
              "minLength": 22
            }
          }
        }
      }
    },
    "catalogdb": {
      "type": "value.v0",
      "connectionString": "{postgres.connectionString};Database=catalogdb"
    },
    "basketcache": {
      "type": "azure.bicep.v0",
      "path": "basketcache-containerapp.bicep",
      "params": {
        "param_0": "{containerAppEnv.outputs.id}"
      }
    },
    "catalogservice": {
      "type": "project.v0",
      "path": "../CatalogService/CatalogService.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "ConnectionStrings__catalogdb": "{catalogdb.connectionString}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "messaging": {
      "type": "azure.bicep.v0",
      "path": "messaging-containerapp.bicep",
      "params": {
        "param_0": "{containerAppEnv.outputs.id}",
        "param_1": "{messaging-containerApp.inputs.password}"
      },
      "inputs": {
        "password": {
          "type": "string",
          "secret": true,
          "default": {
            "generate": {
              "minLength": 22,
              "special": false
            }
          }
        }
      }
    },
    "basketservice": {
      "type": "project.v0",
      "path": "../BasketService/BasketService.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "ConnectionStrings__basketcache": "{basketcache.connectionString}",
        "ConnectionStrings__messaging": "{messaging.connectionString}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http2"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http2"
        }
      }
    },
    "frontend": {
      "type": "project.v0",
      "path": "../MyFrontend/MyFrontend.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "services__basketservice__http__0": "{basketservice.bindings.http.url}",
        "services__basketservice__https__0": "{basketservice.bindings.https.url}",
        "services__catalogservice__http__0": "{catalogservice.bindings.http.url}",
        "services__catalogservice__https__0": "{catalogservice.bindings.https.url}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "orderprocessor": {
      "type": "project.v0",
      "path": "../OrderProcessor/OrderProcessor.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "ConnectionStrings__messaging": "{messaging.connectionString}"
      }
    },
    "apigateway": {
      "type": "project.v0",
      "path": "../ApiGateway/ApiGateway.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "services__basketservice__http__0": "{basketservice.bindings.http.url}",
        "services__basketservice__https__0": "{basketservice.bindings.https.url}",
        "services__catalogservice__http__0": "{catalogservice.bindings.http.url}",
        "services__catalogservice__https__0": "{catalogservice.bindings.https.url}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "catalogdbapp": {
      "type": "project.v0",
      "path": "../CatalogDb/CatalogDb.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "ConnectionStrings__catalogdb": "{catalogdb.connectionString}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "containerAppEnv": {
      "type": "azure.bicep.v0",
      "path": "containerappenv.bicep"
    },
    "containerRegistry": {
      "type": "azure.bicep.v0",
      "path": "containerregistry.bicep"
    },
    "default-identity": {
      "type": "azure.bicep.v0",
      "path": "default-identity.bicep"
    },
    "catalogservice-containerApp": {
      "type": "azure.bicep.v0",
      "path": "catalogservice-containerapp.bicep",
      "params": {
        "param_0": "{containerAppEnv.outputs.id}",
        "param_1": "{containerRegistry.outputs.loginServer}",
        "param_2": "{containerRegistry.outputs.mid}",
        "param_3": "{catalogservice.containerImage}",
        "param_4": "{catalogservice-containerApp.inputs.password}"
      },
      "inputs": {
        "password": {
          "type": "string",
          "secret": true,
          "default": {
            "generate": {
              "minLength": 22
            }
          }
        }
      }
    },
    "basketservice-containerApp": {
      "type": "azure.bicep.v0",
      "path": "basketservice-containerapp.bicep",
      "params": {
        "param_0": "{containerAppEnv.outputs.id}",
        "param_1": "{containerRegistry.outputs.loginServer}",
        "param_2": "{containerRegistry.outputs.mid}",
        "param_3": "{basketservice.containerImage}",
        "param_4": "{basketservice-containerApp.inputs.password}"
      },
      "inputs": {
        "password": {
          "type": "string",
          "secret": true,
          "default": {
            "generate": {
              "minLength": 22,
              "special": false
            }
          }
        }
      }
    },
    "frontend-containerApp": {
      "type": "azure.bicep.v0",
      "path": "frontend-containerapp.bicep",
      "params": {
        "param_0": "{containerAppEnv.outputs.id}",
        "param_1": "{containerRegistry.outputs.loginServer}",
        "param_2": "{containerRegistry.outputs.mid}",
        "param_3": "{frontend.containerImage}",
        "param_4": "{containerAppEnv.outputs.defaultDomain}"
      }
    },
    "orderprocessor-containerApp": {
      "type": "azure.bicep.v0",
      "path": "orderprocessor-containerapp.bicep",
      "params": {
        "param_0": "{containerAppEnv.outputs.id}",
        "param_1": "{containerRegistry.outputs.loginServer}",
        "param_2": "{containerRegistry.outputs.mid}",
        "param_3": "{orderprocessor.containerImage}",
        "param_4": "{orderprocessor-containerApp.inputs.password}"
      },
      "inputs": {
        "password": {
          "type": "string",
          "secret": true,
          "default": {
            "generate": {
              "minLength": 22,
              "special": false
            }
          }
        }
      }
    },
    "apigateway-containerApp": {
      "type": "azure.bicep.v0",
      "path": "apigateway-containerapp.bicep",
      "params": {
        "param_0": "{containerAppEnv.outputs.id}",
        "param_1": "{containerRegistry.outputs.loginServer}",
        "param_2": "{containerRegistry.outputs.mid}",
        "param_3": "{apigateway.containerImage}",
        "param_4": "{containerAppEnv.outputs.defaultDomain}"
      }
    },
    "catalogdbapp-containerApp": {
      "type": "azure.bicep.v0",
      "path": "catalogdbapp-containerapp.bicep",
      "params": {
        "param_0": "{containerAppEnv.outputs.id}",
        "param_1": "{containerRegistry.outputs.loginServer}",
        "param_2": "{containerRegistry.outputs.mid}",
        "param_3": "{catalogdbapp.containerImage}",
        "param_4": "{catalogdbapp-containerApp.inputs.password}"
      },
      "inputs": {
        "password": {
          "type": "string",
          "secret": true,
          "default": {
            "generate": {
              "minLength": 22
            }
          }
        }
      }
    }
  }
}